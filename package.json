{
  "name": "digital-office-nameplate-system",
  "version": "1.0.0",
  "description": "Centralized Digital Office Nameplate System for Raspberry Pi browser displays",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "migrate": "node server/migrate.js",
    "build": "node -e \"console.log('No build step required for this static Express app.')\"",
    "production": "npm run migrate && npm start",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 reload digital-nameplate || pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop digital-nameplate",
    "pm2:status": "pm2 status digital-nameplate",
    "pm2:logs": "pm2 logs digital-nameplate",
    "update": "bash scripts/update.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.7.5",
    "zklib-js": "^1.3.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
